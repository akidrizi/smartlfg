# EditorConfig — SmartLFG
# https://editorconfig.org
# Supported by VS Code, IntelliJ, Vim, Neovim, Sublime, Emacs, and most editors.

root = true

# ------------------------------------------------------------
# Global defaults
# ------------------------------------------------------------
[*]
charset                  = utf-8
end_of_line              = lf
insert_final_newline     = true
trim_trailing_whitespace = true

# ------------------------------------------------------------
# Lua source files
# WoW uses 4-space indentation by convention (matches the
# official Blizzard UI source style).
# ------------------------------------------------------------
[*.lua]
indent_style = space
indent_size  = 4
max_line_length = 120

# ------------------------------------------------------------
# TOC (Table of Contents) — plain text, 4-space indent
# ------------------------------------------------------------
[*.toc]
indent_style = space
indent_size  = 4

# ------------------------------------------------------------
# Markdown documentation
# ------------------------------------------------------------
[*.md]
indent_style             = space
indent_size              = 2
trim_trailing_whitespace = false   # trailing spaces = intentional line-breaks in MD

# ------------------------------------------------------------
# YAML (GitHub Actions, release config, etc.)
# ------------------------------------------------------------
[*.{yml,yaml}]
indent_style = space
indent_size  = 2

# ------------------------------------------------------------
# JSON (VS Code settings, package.json, etc.)
# ------------------------------------------------------------
[*.json]
indent_style = space
indent_size  = 2

# ------------------------------------------------------------
# Shell scripts (packaging helpers)
# ------------------------------------------------------------
[*.sh]
indent_style = space
indent_size  = 2
end_of_line  = lf

# ------------------------------------------------------------
# Windows batch (alternative packaging helper)
# ------------------------------------------------------------
[*.{bat,cmd}]
end_of_line = crlf
